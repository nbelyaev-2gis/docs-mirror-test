{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "Alias": {
      "properties": {
        "name": {
          "type": "string"
        },
        "refLink": {
          "type": "string"
        }
      },
      "required": ["name"],
      "type": "object"
    },
    "ClassProps": {
      "properties": {
        "constructorMethods": {
          "items": {
            "$ref": "#/definitions/MethodProps"
          },
          "type": "array"
        },
        "description": {},
        "implement": {
          "items": {
            "$ref": "#/definitions/Ref"
          },
          "type": "array"
        },
        "inherits": {
          "items": {
            "$ref": "#/definitions/Ref"
          },
          "type": "array"
        },
        "methods": {
          "items": {
            "$ref": "#/definitions/MethodProps"
          },
          "type": "array"
        },
        "name": {
          "type": "string"
        },
        "properties": {
          "items": {
            "$ref": "#/definitions/PropertyProps"
          },
          "type": "array"
        }
      },
      "required": ["name"],
      "type": "object"
    },
    "ClassRef": {
      "properties": {
        "props": {
          "$ref": "#/definitions/ClassProps"
        },
        "type": {
          "enum": ["class"],
          "type": "string"
        }
      },
      "required": ["props", "type"],
      "type": "object"
    },
    "EnumerationProps": {
      "properties": {
        "description": {},
        "implement": {
          "items": {
            "$ref": "#/definitions/Ref"
          },
          "type": "array"
        },
        "methods": {
          "items": {
            "$ref": "#/definitions/MethodProps"
          },
          "type": "array"
        },
        "name": {
          "type": "string"
        },
        "properties": {
          "items": {
            "$ref": "#/definitions/PropertyProps"
          },
          "type": "array"
        }
      },
      "required": ["name", "properties"],
      "type": "object"
    },
    "EnumerationRef": {
      "properties": {
        "props": {
          "$ref": "#/definitions/EnumerationProps"
        },
        "type": {
          "enum": ["enumeration"],
          "type": "string"
        }
      },
      "required": ["props", "type"],
      "type": "object"
    },
    "ExtensionProps": {
      "properties": {
        "description": {},
        "extendTypes": {
          "items": {
            "$ref": "#/definitions/Ref"
          },
          "type": "array"
        },
        "methods": {
          "items": {
            "$ref": "#/definitions/MethodProps"
          },
          "type": "array"
        },
        "name": {
          "type": "string"
        },
        "properties": {
          "items": {
            "$ref": "#/definitions/PropertyProps"
          },
          "type": "array"
        }
      },
      "required": ["extendTypes", "name"],
      "type": "object"
    },
    "ExtensionRef": {
      "properties": {
        "props": {
          "$ref": "#/definitions/ExtensionProps"
        },
        "type": {
          "enum": ["extension"],
          "type": "string"
        }
      },
      "required": ["props", "type"],
      "type": "object"
    },
    "InterfaceProps": {
      "properties": {
        "description": {},
        "inherits": {
          "items": {
            "$ref": "#/definitions/Ref"
          },
          "type": "array"
        },
        "methods": {
          "items": {
            "$ref": "#/definitions/MethodProps"
          },
          "type": "array"
        },
        "name": {
          "type": "string"
        },
        "properties": {
          "items": {
            "$ref": "#/definitions/PropertyProps"
          },
          "type": "array"
        }
      },
      "required": ["name"],
      "type": "object"
    },
    "InterfaceRef": {
      "properties": {
        "props": {
          "$ref": "#/definitions/InterfaceProps"
        },
        "type": {
          "enum": ["interface"],
          "type": "string"
        }
      },
      "required": ["props", "type"],
      "type": "object"
    },
    "MethodProps": {
      "properties": {
        "description": {
          "description": "Описание функции"
        },
        "isConstructor": {
          "description": "Является ли функция конструктором. Передавать true если\nнеобходим префикс \"new\" перед имененем функции",
          "type": "boolean"
        },
        "isOptional": {
          "description": "Функция является опциональной, т.е. может как присутствовать,\nтак и отсутствовать в некоторой структуре",
          "type": "boolean"
        },
        "name": {
          "description": "Формальное имя функции",
          "type": "string"
        },
        "parameters": {
          "description": "Список параметров, принимаемых функцией",
          "items": {
            "$ref": "#/definitions/ParameterProps"
          },
          "type": "array"
        },
        "paramsSignature": {
          "description": "Сигнатура вызова функции. Если не передана, то будет сформирована автоматически",
          "type": "string"
        },
        "result": {
          "$ref": "#/definitions/Result",
          "description": "Описание возвращаемого функцией значения."
        }
      },
      "required": ["name", "parameters"],
      "type": "object"
    },
    "MethodRef": {
      "properties": {
        "props": {
          "$ref": "#/definitions/MethodProps"
        },
        "type": {
          "enum": ["method"],
          "type": "string"
        }
      },
      "required": ["props", "type"],
      "type": "object"
    },
    "ParameterProps": {
      "properties": {
        "description": {
          "description": "Описание параметра"
        },
        "isOptional": {
          "description": "Параметр является опциональным, т.е. его можно не передовать при вызове функции",
          "type": "boolean"
        },
        "name": {
          "description": "Имя параметра",
          "type": "string"
        },
        "types": {
          "description": "Список возможных типов параметра",
          "items": {
            "$ref": "#/definitions/Ref"
          },
          "type": "array"
        }
      },
      "required": ["name", "types"],
      "type": "object"
    },
    "PropertyProps": {
      "properties": {
        "description": {},
        "isOptional": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        },
        "types": {
          "items": {
            "$ref": "#/definitions/Ref"
          },
          "type": "array"
        }
      },
      "required": ["name", "types"],
      "type": "object"
    },
    "Ref": {
      "properties": {
        "name": {
          "description": "Имя типа",
          "type": "string"
        },
        "refLink": {
          "description": "Ссылка на этот тип. Может быть как внешней, так и внутренней.",
          "type": "string"
        }
      },
      "required": ["name"],
      "type": "object"
    },
    "ReferencesMap": {
      "additionalProperties": {
        "anyOf": [
          {
            "$ref": "#/definitions/ClassRef"
          },
          {
            "$ref": "#/definitions/MethodRef"
          },
          {
            "$ref": "#/definitions/InterfaceRef"
          },
          {
            "$ref": "#/definitions/TypeAliasRef"
          },
          {
            "$ref": "#/definitions/EnumerationRef"
          },
          {
            "$ref": "#/definitions/ExtensionRef"
          },
          {
            "$ref": "#/definitions/StructRef"
          }
        ]
      },
      "type": "object"
    },
    "Result": {
      "properties": {
        "description": {
          "description": "Описание возвращаемого значения"
        },
        "types": {
          "description": "Список возможных типов возвращаемого значения",
          "items": {
            "$ref": "#/definitions/Ref"
          },
          "type": "array"
        }
      },
      "required": ["types"],
      "type": "object"
    },
    "StructProps": {
      "properties": {
        "constructorMethods": {
          "items": {
            "$ref": "#/definitions/MethodProps"
          },
          "type": "array"
        },
        "description": {},
        "implement": {
          "items": {
            "$ref": "#/definitions/Ref"
          },
          "type": "array"
        },
        "methods": {
          "items": {
            "$ref": "#/definitions/MethodProps"
          },
          "type": "array"
        },
        "name": {
          "type": "string"
        },
        "properties": {
          "items": {
            "$ref": "#/definitions/PropertyProps"
          },
          "type": "array"
        }
      },
      "required": ["name"],
      "type": "object"
    },
    "StructRef": {
      "properties": {
        "props": {
          "$ref": "#/definitions/StructProps"
        },
        "type": {
          "enum": ["struct"],
          "type": "string"
        }
      },
      "required": ["props", "type"],
      "type": "object"
    },
    "TypeAliasProps": {
      "properties": {
        "aliases": {
          "items": {
            "$ref": "#/definitions/Alias"
          },
          "type": "array"
        },
        "description": {},
        "name": {
          "type": "string"
        }
      },
      "required": ["aliases", "name"],
      "type": "object"
    },
    "TypeAliasRef": {
      "properties": {
        "props": {
          "$ref": "#/definitions/TypeAliasProps"
        },
        "type": {
          "enum": ["typeAlias"],
          "type": "string"
        }
      },
      "required": ["props", "type"],
      "type": "object"
    }
  },
  "properties": {
    "config": {
      "description": "Конфиг для автосборки референса\nДополняется по мере развития проекта",
      "properties": {
        "textProvider": {
          "description": "Как обрабатывать текст в таких блоках как\n\"описание метода\" - markdown или готовый HTML",
          "enum": ["html", "md"],
          "type": "string"
        }
      },
      "required": ["textProvider"],
      "type": "object"
    },
    "refMap": {
      "$ref": "#/definitions/ReferencesMap",
      "description": "Карта вида \"путь до reference -> конфиг reference\",\nПример:\n{\n  \"/ru/reference/geocoder\": { type: 'typeAlias' }\n}"
    }
  },
  "required": ["config", "refMap"],
  "type": "object"
}
