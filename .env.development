# DO NOT ADD SECRETS TO THIS FILE. This is a good place for defaults.
# If you want to add secrets use `.env.development.local` instead.
# https://nextjs.org/docs/basic-features/environment-variables

BRAND=2gis
APP_URL=http://localhost:3000
DISTRIBUTION_MODE=public

# отключаем аналитику по умолчанию
GA_TRACKING_ID=

UX_FEEDBACK_ID=

SEARCH_API_URL=https://docs-search.api.k8s.2gis.dev
SEARCH_API_COLLECTION=2gis-kit-docs

CHAT_BOT_API_URL=https://twogis-api-docs-search.k8s.2gis.dev
