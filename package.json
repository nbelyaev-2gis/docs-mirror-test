{
  "name": "kit-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "docusaurus": "docusaurus",
    "start": "npm run build-sdk-pages-dev && docusaurus start",
    "build": "npm run build-sdk-pages-prod && docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "npm run build-sdk-pages-dev && docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-translations-en": "docusaurus write-translations --locale en",
    "write-heading-ids": "docusaurus write-heading-ids",
    "build-sdk-pages-dev": "tsx ./src/shared/docusaurus/plugin-sdk-reference/model/buildReferencePages.ts dev",
    "build-sdk-pages-prod": "tsx ./src/shared/docusaurus/plugin-sdk-reference/model/buildReferencePages.ts",
    "test:cmd:prettier-check": "prettier -c --cache --ignore-unknown .",
    "test:cmd:tsc": "tsc --noEmit --extendedDiagnostics --incremental",
    "test:cmd:eslint": "eslint . --cache",
    "test:env:pre-push": "npm-run-all test:cmd:*",
    "test:env:ci-dev": "npm-run-all test:cmd:prettier-check test:cmd:tsc test:cmd:eslint",
    "prettier:write": "prettier --write .",
    "screen:test:ui": "playwright test --ui",
    "screen:test:run": "playwright test",
    "screen:test:update": "playwright test --update-snapshots",
    "rag:index-docs-references": "tsx ./tools/indexDocsReferences/index.ts"
  },
  "lint-staged": {
    "*": "prettier --write"
  },
  "dependencies": {
    "@2gis/mapgl": "^1.56.0",
    "@docusaurus/preset-classic": "3.9.1",
    "@mdx-js/react": "^3.0.0",
    "@radix-ui/react-slot": "1.2.3",
    "@radix-ui/react-tabs": "1.1.13",
    "axios": "1.10.0",
    "clsx": "2.1.1",
    "configure-postcss": "file:plugins/configure-postcss",
    "dom-serializer": "2.0.0",
    "domhandler": "5.0.3",
    "domutils": "3.2.2",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^8.0.0",
    "downshift": "9.0.9",
    "htmlparser2": "^9.1.0",
    "ky": "1.14.2",
    "lodash.debounce": "4.0.8",
    "my-alias": "file:plugins/my-alias",
    "prism-react-renderer": "^2.3.0",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-markdown": "10.1.0",
    "react-transition-group": "4.4.5",
    "redoc": "2.5.1",
    "redocusaurus": "2.5.0",
    "rehype-raw": "7.0.0",
    "remark-gfm": "4.0.1",
    "strip-indent": "^4.0.0",
    "tsx": "^4.19.3",
    "typesense": "2.0.3",
    "unified": "^11.0.5",
    "uuid": "13.0.0",
    "zod": "3.25.41",
    "zustand": "5.0.9"
  },
  "devDependencies": {
    "@babel/parser": "^7.26.2",
    "@babel/preset-env": "^7.26.0",
    "@babel/types": "^7.26.0",
    "@docusaurus/core": "3.9.1",
    "@docusaurus/module-type-aliases": "3.9.1",
    "@docusaurus/plugin-content-docs": "3.9.1",
    "@docusaurus/tsconfig": "3.9.1",
    "@docusaurus/types": "3.9.1",
    "@eslint/js": "9.27.0",
    "@playwright/test": "1.55.0",
    "@types/express": "4.17.21",
    "@types/fs-extra": "11.0.4",
    "@types/he": "1.2.3",
    "@types/lodash.debounce": "4.0.9",
    "@types/node": "22.13.10",
    "@types/react-dom": "18.0.0",
    "@types/react-transition-group": "4.4.12",
    "@types/semver": "7.7.1",
    "allure-playwright": "3.6.0",
    "cheerio": "1.0.0",
    "easy-pdf-merge": "0.2.6",
    "eslint": "9.27.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "estree-util-visit": "2.0.0",
    "express": "4.21.2",
    "fs-extra": "11.3.0",
    "github-slugger": "2.0.0",
    "globals": "16.1.0",
    "html-toc": "2.0.0",
    "husky": "9.1.7",
    "lint-staged": "15.5.2",
    "minimatch": "10.0.1",
    "net": "1.0.2",
    "npm-run-all2": "8.0.3",
    "path": "0.12.7",
    "pdf-parse": "1.1.1",
    "postcss-custom-media": "8.0.2",
    "postcss-import": "16.1.0",
    "prettier": "3.5.3",
    "puppeteer": "24.4.0",
    "semver": "7.7.3",
    "swagger-markdown": "3.0.0",
    "ts-node": "10.9.2",
    "typescript": "5.8.3",
    "typescript-eslint": "8.32.1",
    "unist-util-visit": "5.0.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
